# URL del notification-gateway (mismo host en prod)
GATEWAY_URL=http://localhost:8090

# API key emitida por el gateway para atalaya (panel → API Keys, o npm run create-key)
ATALAYA_API_KEY=

# Destinatarios de las alertas: lista separada por comas, formato internacional
# ej: ALERT_RECIPIENTS=+15555550100,+15555550101
ALERT_RECIPIENTS=

# Hora local (0-23) del digest diario — que además hace de heartbeat:
# se envía SIEMPRE, aunque no haya novedades; si un día no llega, el host está mal
DIGEST_HOUR=21

LOG_LEVEL=info

# Monitoreo de hosts: off | dry-run | live
HOST_MONITOR_MODE=off
HOST_SYSTEM_MOUNTS=/
HOST_MEDIA_MOUNTS=/media/example
SMART_SNAPSHOT_COMMAND=/usr/local/sbin/atalaya-smart-snapshot
LIBRETORIO_BACKUP_DIR=/path/to/database-backups

# name|url|status;name2|url2|status
EDGE_CANARY_URL=https://gateway.example.com/admin/
EDGE_CANARY_EXPECTED_STATUS=200
CANARY_TARGETS=app|https://app.example.com/|200

# Acceso restringido a un snapshot JSON remoto
VPS_MONITOR_HOST=203.0.113.10
VPS_MONITOR_USER=monitor
VPS_MONITOR_PORT=22
VPS_MONITOR_KEY=/home/user/.ssh/atalaya_vps_ed25519

# Gluetun: rol API limitado a lectura. La clave vive solo en .env privado.
GLUETUN_CONTAINER=gluetun
GLUETUN_CONTROL_PORT=8000
GLUETUN_CONTROL_API_KEY=

# qBittorrent: URL local publicada por Gluetun y credencial de solo monitoreo.
QBITTORRENT_URL=http://127.0.0.1:9080
QBITTORRENT_USERNAME=
QBITTORRENT_PASSWORD=

# Jellyfin: eventos inmediatos de sesiones/reproduccion. La IP se resuelve localmente.
JELLYFIN_URL=http://127.0.0.1:8096
JELLYFIN_API_KEY=
GEOIP_CITY_DATABASE=/home/user/atalaya-geoip/GeoLite2-City.mmdb
GEOIP_LOOKUP_COMMAND=/home/user/.local/opt/mmdb-bin/usr/bin/mmdblookup

# Aonsoku: SPA estatica. Se comprueban inicio, configuracion y errores Nginx agregados.
AONSOKU_URL=http://127.0.0.1:8082
AONSOKU_CONTAINER=aonsoku
AONSOKU_CHECK_MS=60000

# Navidrome: ping, Now Playing via cuenta tecnica y metricas Prometheus protegidas.
NAVIDROME_URL=http://127.0.0.1:4533
NAVIDROME_CONTAINER=navidrome
NAVIDROME_USERNAME=atalaya-monitor
NAVIDROME_PASSWORD=
NAVIDROME_METRICS_URL=http://127.0.0.1:4533/metrics_private_path
NAVIDROME_METRICS_PASSWORD=
NAVIDROME_CHECK_MS=60000
# Correlaciona cliente/IP desde el proxy OCI; solo conserva ciudad/pais localmente.
NAVIDROME_CLIENT_LOCATION_ENABLED=false
SERVICE_LOG_CHECK_MS=60000
